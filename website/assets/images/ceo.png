<svg xmlns="http://www.w3.org/2000/svg" width="400" height="500" viewBox="0 0 400 500">
  <rect width="400" height="500" fill="#111"/>
  <rect width="400" height="500" fill="url(#grad)" opacity=".6"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C8860A;stop-opacity:.15"/>
      <stop offset="100%" style="stop-color:transparent;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <line x1="0" y1="0" x2="400" y2="500" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <line x1="400" y1="0" x2="0" y2="500" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <circle cx="200" cy="230" r="48" fill="none" stroke="#C8860A" stroke-opacity=".25" stroke-width="1.5"/>
  <text x="200" y="258" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="18" font-weight="700"
    fill="#C8860A" opacity=".7">Giám Đốc Điều Hành</text>
  <text x="200" y="286" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="8.799999999999999" font-weight="400"
    fill="rgba(255,255,255,.3)">SAO VÀNG</text>
</svg>