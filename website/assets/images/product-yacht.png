<svg xmlns="http://www.w3.org/2000/svg" width="600" height="450" viewBox="0 0 600 450">
  <rect width="600" height="450" fill="#0d0d1a"/>
  <rect width="600" height="450" fill="url(#grad)" opacity=".6"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C8860A;stop-opacity:.15"/>
      <stop offset="100%" style="stop-color:transparent;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <line x1="0" y1="0" x2="600" y2="450" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <line x1="600" y1="0" x2="0" y2="450" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <circle cx="300" cy="205" r="54" fill="none" stroke="#C8860A" stroke-opacity=".25" stroke-width="1.5"/>
  <text x="300" y="233" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="20.25" font-weight="700"
    fill="#C8860A" opacity=".7">Nội Thất Du Thuyền</text>
  <text x="300" y="261" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="9.899999999999999" font-weight="400"
