<svg xmlns="http://www.w3.org/2000/svg" width="800" height="600" viewBox="0 0 800 600">
  <rect width="800" height="600" fill="#0d0d1a"/>
  <rect width="800" height="600" fill="url(#grad)" opacity=".6"/>
  <defs>
    <linearGradient id="grad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#C8860A;stop-opacity:.15"/>
      <stop offset="100%" style="stop-color:transparent;stop-opacity:0"/>
    </linearGradient>
  </defs>
  <line x1="0" y1="0" x2="800" y2="600" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <line x1="800" y1="0" x2="0" y2="600" stroke="#C8860A" stroke-opacity=".08" stroke-width="1"/>
  <circle cx="400" cy="280" r="72" fill="none" stroke="#C8860A" stroke-opacity=".25" stroke-width="1.5"/>
  <text x="400" y="308" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="27" font-weight="700"
    fill="#C8860A" opacity=".7">Penthouse HN</text>
  <text x="400" y="336" text-anchor="middle" dominant-baseline="middle"
    font-family="Arial, sans-serif" font-size="13.2" font-weight="400"
    fill="rgba(255,255,255,.3)">SAO VÀNG</text>
</svg>